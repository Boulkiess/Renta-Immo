{
  "name": "@immo-renta/engine",
  "version": "0.1.0",
  "description": "Pure financial engine for French real-estate investment analysis (LMNP, foncier nu, micro-BIC, plus-value art. 150 VC CGI, ETF reference scenario). Zero runtime dependencies.",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:types": "tsc -p tsconfig.json",
    "prepack": "npm run build:types"
  },
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {}
}
